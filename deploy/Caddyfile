# TLS termination for Melon. Caddy obtains and renews the certificate itself
# (ACME HTTP-01 on :80), so the cert volume must persist.

{
	email {$MELON_ACME_EMAIL}
}

{$MELON_DOMAIN} {
	encode zstd gzip

	header {
		# HSTS: sign-on cookies are Secure; never let a browser downgrade.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# The admin/merchant SPAs must never be framed (clickjacking on money ops).
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		# The SPAs are fully self-contained: no external scripts, styles or fonts.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'none'"
		-Server
	}

	reverse_proxy server:8080 {
		# The terminal's mutual-authentication relay is chatty but small; the
		# defaults are fine. Fail fast if the single server instance is down.
		health_uri /healthz
		health_interval 15s
	}

	log {
		output stdout
		format json
	}
}
