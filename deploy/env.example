# Melon production config — copy to `deploy/.env`.
# NON-SECRET values only. Secrets live in `deploy/secrets/` (see compose.yaml).

# --- required ---
# The first issuer/admin account, created on first start only (idempotent).
# Its PASSWORD goes in deploy/secrets/bootstrap_admin_password, not here.
MELON_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# --- Cloudflare Tunnel (dashboard-managed) ---
# Zero Trust → Networks → Tunnels → Create a tunnel → Cloudflared → copy the token.
# Then add a Public hostname:  melon.example.com  →  HTTP  →  server:8080
# (the compose service name — NOT localhost:8080).
#
# ⚠️ This is the ONE secret that cannot live in deploy/secrets/: the cloudflared
#    image is distroless and has no *_FILE support, so the token has to be an
#    environment value. Keep this file at mode 600 (`chmod 600 .env`); the token
#    is visible to anyone who can run `docker inspect` on this host. Rotate it in
#    the dashboard if it leaks — it only authorizes running the tunnel.
CLOUDFLARE_TUNNEL_TOKEN=

# --- image ---
MELON_VERSION=latest

# --- business defaults for newly created merchants ---
# Payment fee in basis points (150 = 1.50%).
MELON_DEFAULT_FEE_BPS=0
# How far a merchant's settlement may go negative to sell top-ups (yen).
# NOTE: 0 means a new merchant cannot sell any top-up until granted a limit.
MELON_DEFAULT_CREDIT_LIMIT=0

# --- sessions ---
# Sign-on cookie lifetime (seconds). 43200 = 12h.
MELON_USER_SESSION_TTL=43200
# FeliCa mutual-auth session idle TTL (seconds) and cap.
FELICA_SESSION_TTL=300
FELICA_MAX_SESSIONS=1024

# --- operations ---
# Expiry sweep interval (seconds).
MELON_SWEEP_INTERVAL_SECS=3600
RUST_LOG=info
